---
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
---

<div class={`subscribe-form${compact ? ' subscribe-form--compact' : ''}`}>
  <iframe
    src="https://transatlanticintelligence.substack.com/embed"
    width="100%"
    height="320"
    frameborder="0"
    scrolling="no"
  ></iframe>
</div>

<style>
  .subscribe-form {
    width: 100%;
  }

  .subscribe-form--compact {
    max-width: 480px;
  }

  .subscribe-form iframe {
    display: block;
    border: none;
    background: transparent;
  }
</style>
