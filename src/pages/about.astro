---
import Base from '../layouts/Base.astro';
---

<Base title="About — Transatlantic Intelligence">
  <div class="about">
    <h1>About</h1>

    <p>
      <strong>Transatlantic Intelligence</strong> covers the business and
      governance of artificial intelligence — how organisations are adopting
      it, how to use it effectively, how governments are regulating it, and
      what the transatlantic relationship means for the future of AI.
    </p>

    <p>
      Written by Suzanne, with a focus on the Atlantic crossing between
      American innovation and European regulation.
    </p>

    <div class="subscribe-block">
      <h2>Subscribe</h2>
      <iframe
        src="https://transatlanticintelligence.substack.com/embed"
        width="100%"
        height="320"
        style="border:1px solid #e5e7eb; background:white; max-width:480px;"
        frameborder="0"
        scrolling="no"
      ></iframe>
    </div>
  </div>
</Base>
