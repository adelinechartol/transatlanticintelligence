---
import { getPosts } from '../lib/substack.js';

const posts = await getPosts();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Transatlantic Intelligence</title>
    <meta name="description" content="The business and governance of AI, across the US and Europe." />
  </head>
  <body>
    <header>
      <h1>Transatlantic Intelligence</h1>
      <p>The business and governance of AI, across the US and Europe.</p>
      <nav>
        <a href="/">Home</a> · <a href="/about">About</a>
      </nav>
    </header>

    <main>
      <h2>Recent posts</h2>
      {posts.length === 0 ? (
        <p>No posts yet — check back soon.</p>
      ) : (
        <ul>
          {posts.map((post) => (
            <li>
              <a href={`/posts/${post.slug}/`}>
                <h3>{post.title}</h3>
                <time datetime={post.pubDate.toISOString()}>
                  {post.pubDate.toLocaleDateString('en-GB', {
                    year: 'numeric', month: 'long', day: 'numeric'
                  })}
                </time>
                <p>{post.description}</p>
              </a>
            </li>
          ))}
        </ul>
      )}
    </main>

    <footer>
      <p>Written by Suzanne. Delivered via <a href="https://transatlanticintelligence.substack.com">Substack</a>.</p>
    </footer>
  </body>
</html>
