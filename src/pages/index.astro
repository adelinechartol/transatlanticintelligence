---
import Base from '../layouts/Base.astro';
import { getPosts } from '../lib/substack.js';

const posts = await getPosts();
---

<Base title="Transatlantic Intelligence">
  <h2 class="section-label">Recent dispatches</h2>

  {posts.length === 0 ? (
    <p>No posts yet — check back soon.</p>
  ) : (
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <a href={`/posts/${post.slug}/`}>
            <p class="post-list-meta">
              <time datetime={post.pubDate.toISOString()}>
                {post.pubDate.toLocaleDateString('en-GB', {
                  year: 'numeric', month: 'long', day: 'numeric'
                })}
              </time>
            </p>
            <h2 class="post-list-title">{post.title}</h2>
            <p class="post-list-desc">{post.description}</p>
          </a>
        </li>
      ))}
    </ul>
  )}
</Base>
