---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('posts', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.mdx?$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const post = entry.data;
---

<Base title={`${post.title} — Transatlantic Intelligence`} description={post.description}>
  <p class="article-back"><a href="/">← All dispatches</a></p>

  <article class="article">
    <h1 class="article-title">{post.title}</h1>
    <p class="article-meta">
      By <strong>{post.author}</strong> ·
      <time datetime={post.pubDate.toISOString()}>
        {post.pubDate.toLocaleDateString('en-GB', {
          year: 'numeric', month: 'long', day: 'numeric'
        })}
      </time>
    </p>

    <div class="article-body">
      <Content />
    </div>

    {post.substackUrl && (
      <p class="article-footer">
        Also published on <a href={post.substackUrl}>Substack</a>.
        Subscribe to get new dispatches by email.
      </p>
    )}
  </article>
</Base>
