---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'The business and governance of AI, across the US and Europe.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,600;8..60,700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="wrap masthead">
      <svg class="masthead-arch" viewBox="0 0 200 56" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M 10 48 Q 100 4 190 48" stroke="#c9a84c" stroke-width="1.5" fill="none"/>
        <circle cx="10" cy="48" r="4.5" fill="#c9a84c"/>
        <circle cx="190" cy="48" r="4.5" fill="#c9a84c"/>
      </svg>
      <h1 class="masthead-title">
        <a href="/">Transatlantic Intelligence</a>
      </h1>
      <p class="masthead-tagline">AI · Business · Governance</p>
      <nav class="masthead-nav">
        <a href="/">Home</a>
        <div class="nav-dropdown">
          <a href="/about">About</a>
          <div class="nav-dropdown-menu">
            <a href="/about#newsletter">About the Newsletter</a>
            <a href="/about#authors">About the Authors</a>
          </div>
        </div>
      </nav>
      <div class="masthead-subscribe">
        <a href="https://transatlanticintelligence.substack.com/subscribe" class="masthead-subscribe-btn">Subscribe</a>
      </div>
    </header>

    <main class="wrap">
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        Transatlantic Intelligence &middot; Written by Suzanne Chartol &amp; Adeline Chartol &middot;
        Delivered via <a href="https://transatlanticintelligence.substack.com">Substack</a>
      </p>
    </footer>
  </body>
</html>
