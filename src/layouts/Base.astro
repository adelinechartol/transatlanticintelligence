---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'The business and governance of AI, across the US and Europe.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,600;8..60,700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="wrap masthead">
      <h1 class="masthead-title">
        <a href="/">Transatlantic Intelligence</a>
      </h1>
      <p class="masthead-tagline">AI · Business · Governance</p>
      <nav class="masthead-nav">
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="https://transatlanticintelligence.substack.com">Subscribe</a>
      </nav>
    </header>

    <main class="wrap">
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        Transatlantic Intelligence &middot; Written by Suzanne &middot;
        Delivered via <a href="https://transatlanticintelligence.substack.com">Substack</a>
      </p>
    </footer>
  </body>
</html>
