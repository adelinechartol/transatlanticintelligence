---
import '../styles/global.css';
import SubscribeForm from '../components/SubscribeForm.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'The business and governance of AI, across the US and Europe.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:opsz,wght@8..60,400;8..60,600;8..60,700&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      if (localStorage.getItem('lang') === 'fr') {
        document.documentElement.classList.add('lang-fr');
        document.documentElement.lang = 'fr';
      }
    </script>
  </head>
  <body>
    <button class="lang-toggle" id="lang-toggle" aria-label="Switch language">
      <span class="t-en">FR</span>
      <span class="t-fr">EN</span>
    </button>

    <header class="wrap masthead">
      <svg class="masthead-arch" viewBox="0 0 200 56" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M 10 48 Q 100 4 190 48" stroke="#3b72c4" stroke-width="1.5" fill="none"/>
        <circle cx="10" cy="48" r="4.5" fill="#3b72c4"/>
        <circle cx="190" cy="48" r="4.5" fill="#3b72c4"/>
      </svg>
      <h1 class="masthead-title">
        <a href="/">Transatlantic Intelligence</a>
      </h1>
      <p class="masthead-tagline">
        <span class="t-en">AI · Business · Governance</span>
        <span class="t-fr">IA · Économie · Gouvernance</span>
      </p>
      <nav class="masthead-nav">
        <a href="/">
          <span class="t-en">Home</span>
          <span class="t-fr">Accueil</span>
        </a>
        <div class="nav-dropdown">
          <a href="/about">
            <span class="t-en">About</span>
            <span class="t-fr">À propos</span>
          </a>
          <div class="nav-dropdown-menu">
            <a href="/about">
              <span class="t-en">About the Newsletter</span>
              <span class="t-fr">À propos de la newsletter</span>
            </a>
            <a href="/about/authors">
              <span class="t-en">About the Authors</span>
              <span class="t-fr">À propos des auteurs</span>
            </a>
          </div>
        </div>
      </nav>
      <div class="masthead-subscribe">
        <a href="https://transatlanticintelligence.substack.com/subscribe" class="masthead-subscribe-btn">
          <span class="t-en">Subscribe</span>
          <span class="t-fr">S'abonner</span>
        </a>
      </div>
    </header>

    <main class="wrap">
      <slot />
    </main>

    <section class="global-subscribe wrap">
      <h2 class="global-subscribe__label">
        <span class="t-en">Subscribe</span>
        <span class="t-fr">S'abonner</span>
      </h2>
      <p class="global-subscribe__blurb">
        <span class="t-en">AI and governance, across the Atlantic — delivered to your inbox.</span>
        <span class="t-fr">IA et gouvernance, de part et d'autre de l'Atlantique — dans votre boîte mail.</span>
      </p>
      <SubscribeForm />
    </section>

    <footer class="site-footer">
      <p>
        <span class="t-en">
          Transatlantic Intelligence &middot; Written by Suzanne Chartol &amp; Adeline Chartol &middot;
          Delivered via <a href="https://transatlanticintelligence.substack.com">Substack</a>
        </span>
        <span class="t-fr">
          Transatlantic Intelligence &middot; Écrit par Suzanne Chartol et Adeline Chartol &middot;
          Publié via <a href="https://transatlanticintelligence.substack.com">Substack</a>
        </span>
      </p>
    </footer>

    <script>
      const toggle = document.getElementById('lang-toggle') as HTMLButtonElement | null;
      toggle?.addEventListener('click', () => {
        const isFr = document.documentElement.classList.toggle('lang-fr');
        document.documentElement.lang = isFr ? 'fr' : 'en';
        localStorage.setItem('lang', isFr ? 'fr' : 'en');
      });
    </script>
  </body>
</html>
